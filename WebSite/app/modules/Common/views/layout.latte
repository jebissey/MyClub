<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{block title}MyClub{/block}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/app/modules/Common/css/layout.css" rel="stylesheet">
    <style>
        :root {
            --navbar-ink:  {$navbarInkColor|noescape};
            --navbar-icon: {$navbarIconColor|noescape};
        }

        .navbar {
            background-color: color-mix(in srgb, {$navbarBgColor|noescape} 55%, transparent) !important;
            --bs-navbar-color:        {$navbarInkColor|noescape};
            --bs-navbar-hover-color:  {$navbarInkColor|noescape};
            --bs-navbar-active-color: {$navbarInkColor|noescape};
            --bs-navbar-brand-color:  {$navbarInkColor|noescape};
            --bs-nav-link-color:      {$navbarInkColor|noescape};
        }
        .navbar .bi { color: {$navbarIconColor|noescape}; }

        #sidebar {
            background-color: {$navbarBgColor|noescape};
        }
        #sidebarNav .nav-link,
        #sidebarNav .collapse-submenu .nav-link,
        .sidebar-heading {
            color: {$navbarInkColor|noescape} !important;
            opacity: 0.7;
        }
        #sidebarNav .nav-link:hover,
        #sidebarNav .nav-link.active {
            opacity: 1;
        }
    </style>
    {php Tracy\Debugger::renderLoader()}
    {block head}{/block}
</head>

<body>

    {if isset($productionSiteUrl)}
        <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0 text-center py-3" role="alert"
             style="position:relative; z-index:300;">
            <h2><i class="bi bi-exclamation-triangle-fill"></i> {='layout.alert.test_site.title'|translate}</h2>
            {='layout.alert.test_site.message'|translate}
            <a href="{$productionSiteUrl}" class="alert-link fw-bold">{='layout.alert.test_site.link'|translate}</a>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {/if}
    {if isset($memberAlert)}
        <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0 text-center py-3" role="alert"
             style="position:relative; z-index:300;">
            <h2><i class="bi bi-exclamation-triangle-fill"></i> {$memberAlert}</h2>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {/if}

    <div class="toast-container position-fixed top-0 end-0 p-3" id="toastContainer" style="z-index:1100;"></div>

    <nav class="navbar navbar-expand-lg shadow-sm">
        {block sidebar_toggle}{/block}
        {block navbar}{/block}
    </nav>

    <div id="app-body" class="d-flex overflow-hidden">
        {block sidebar}{/block}

        <main id="content" class="overflow-y-auto d-flex flex-column">
            <div class="banner" style="margin-top: 0;">
                {block banner}{/block}
            </div>

            <div id="content-inner" class="container-fluid flex-grow-1" style="margin-top: var(--navbar-height);">
                {block content}{/block}

                <div id="saveIndicator" class="bg-white rounded-circle shadow"
                     title="{='layout.save_indicator.title'|translate}">
                    <i class="bi bi-save"></i>
                </div>
            </div>

            {block footer}{/block}
         
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="/app/modules/Common/js/layout.js"></script>
    <script>
        window.i18n = {
            unsavedWarning:    {='layout.save_guard.unsaved_warning'|translate},
            iosInstallMessage: {='layout.pwa.ios_install.message'|translate}
        };
        window.t = function(key) {
            return window.i18n?.[key] ?? key;
        };
    </script>
    {block scripts}{/block}
</body>
</html>
