<!DOCTYPE html>
<html lang="fr" class="min-vh-100">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <title>{block title}MyClub{/block}</title>
    {php Tracy\Debugger::renderLoader()}
    <style>
        /* ─── Sidebar ────────────────────────────────────────────── */
        :root {
            --sidebar-width: 200px;
        }

        #sidebar-wrapper {
            width: var(--sidebar-width);
            min-width: var(--sidebar-width);
            position: sticky;
            top: 56px; /* navbar height */
            height: calc(100vh - 98px);
            overflow-y: auto;
        }

        #sidebar-wrapper .nav-link {
            color: rgba(255,255,255,.75);
            padding: .5rem 1.25rem;
            font-size: .9rem;
            white-space: nowrap;
            border-left: 3px solid transparent;
            transition: color .15s, border-color .15s, background .15s;
        }

        #sidebar-wrapper .nav-link:hover,
        #sidebar-wrapper .nav-link.active {
            color: #fff;
            background-color: rgba(255,255,255,.06);
            border-left-color: #0d6efd;
        }

        #sidebar-wrapper .nav-link i {
            width: 18px;
            text-align: center;
            margin-right: .5rem;
        }

        .sidebar-heading {
            padding: .875rem 1.25rem;
            font-size: .75rem;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: rgba(255,255,255,.4);
            font-weight: 600;
        }

        .sidebar-divider {
            border-top: 1px solid rgba(255,255,255,.1);
            margin: .5rem 0;
        }

        #sidebar-wrapper .collapse-submenu .nav-link {
            padding-left: 2.75rem;
            font-size: .85rem;
        }

        /* ─── Background watermark ───────────────────────────────── */
        .content-wrapper::before {
            content: "";
            background: url('/app/images/logo.png') no-repeat center / 50%;
            opacity: .2;
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: -1;
        }

        /* ─── Modals ──────────────────────────────────────────────── */
        .modal { z-index: 1055 !important; }
        .modal-backdrop { z-index: 1050 !important; }

        /* ─── Save indicator ─────────────────────────────────────── */
        #saveIndicator {
            position: fixed;
            bottom: 20px;
            right: 20px;
            display: none;
            background: white;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            box-shadow: 0 2px 10px rgba(0,0,0,.2);
            z-index: 1050;
            cursor: pointer;
            transition: transform .2s;
        }

        #saveIndicator:hover { transform: scale(1.1); }

        #saveIndicator i {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%,-50%);
            font-size: 1.5rem;
            color: #0d6efd;
        }

        /* ─── Utilities ──────────────────────────────────────────── */
        .attribute-badge {
            display: inline-block;
            width: 20px;
            height: 20px;
            margin-right: 5px;
            border-radius: 4px;
            cursor: help;
            border: 1px solid rgba(0,0,0,.2);
        }

        .double-strike {
            text-decoration: line-through double;
        }

        nav.navbar .navbar-nav .nav-link {
            padding-top: .1rem;
            padding-bottom: .1rem;
        }

        .img-left   { float: left !important;  margin: 0 15px 10px 0 !important; max-width: 100%; height: auto; }
        .img-right  { float: right !important; margin: 0 0 10px 15px !important; max-width: 100%; height: auto; }
        .img-center { display: block !important; margin: 10px auto !important; float: none !important; max-width: 100%; height: auto; }

        .custom-img {
            height: clamp(80px, 20vw, 220px);
            width: 100%;
            object-fit: cover;
        }

        @media (max-width: 576px) {
            .custom-img { height: clamp(60px, 18vw, 110px); }
        }
    </style>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="{$themeColor ?? '#0d6efd'}">
    {block head}{/block}
</head>

<body class="d-flex flex-column min-vh-100">

    {* ── Alerts ──────────────────────────────────────────────────── *}
    {if isset($productionSiteUrl)}
        <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0 text-center py-3" role="alert">
            <h2><i class="bi bi-exclamation-triangle-fill"></i> ATTENTION : Site de test</h2>
            Vous êtes sur un environnement de test.
            <a href="{$productionSiteUrl}" class="alert-link fw-bold">Accéder au site de production</a>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {/if}
    {if isset($memberAlert)}
        <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0 text-center py-3" role="alert">
            <h2><i class="bi bi-exclamation-triangle-fill"></i> {$memberAlert}</h2>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {/if}

    <div class="toast-container position-fixed top-0 end-0 p-3" id="toastContainer"></div>

    <div class="content-wrapper d-flex flex-column min-vh-100">
        <main class="flex-grow-1 d-flex flex-column">

            {* ── Navbar ──────────────────────────────────────────── *}
            <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
                {* Sidebar toggle — visible uniquement sur grands écrans si sidebar active *}
                {if isset($sidebarMenu) && count($sidebarMenu) > 0}
                    <button id="sidebarToggle"
                            class="d-none d-lg-flex align-items-center justify-content-center me-2 border-0 bg-transparent text-white-50 rounded"
                            style="width:34px;height:34px;font-size:1.1rem;transition:background .15s,color .15s;cursor:pointer;"
                            title="Afficher/masquer le menu">
                        <i class="bi bi-layout-sidebar"></i>
                    </button>
                {/if}
                {block navbar}{/block}
            </nav>

            {* ── Sidebar + content wrapper ───────────────────────── *}
            <div id="wrapper" class="d-flex flex-grow-1">

                {* ── Sidebar — masquée sur mobile, visible dès lg ── *}
                {if isset($sidebarMenu) && count($sidebarMenu) > 0}
                    <div id="sidebar-wrapper" class="d-none d-lg-flex flex-column bg-dark flex-shrink-0">
                        {block sidebar}
                            <nav class="py-2">
                                {foreach $sidebarMenu as $item}
                                    {if $item['type'] === 'heading'}
                                        <div class="sidebar-heading">{$item['label']}</div>

                                    {elseif $item['type'] === 'divider'}
                                        <hr class="sidebar-divider">

                                    {elseif $item['type'] === 'link'}
                                        <a href="{$item['url']}"
                                           class="nav-link{if isset($currentPath) && $currentPath === $item['url']} active{/if}">
                                            <i class="bi {isset($item['icon']) ? $item['icon'] : 'bi-circle'}"></i>
                                            {$item['label']}
                                        </a>

                                    {elseif $item['type'] === 'submenu'}
                                        {var $submenuId = 'submenu-' . $iterator->counter}
                                        <a class="nav-link d-flex align-items-center justify-content-between"
                                           data-bs-toggle="collapse"
                                           href="#{$submenuId}"
                                           role="button"
                                           aria-expanded="false">
                                            <span>
                                                <i class="bi {isset($item['icon']) ? $item['icon'] : 'bi-folder'}"></i>
                                                {$item['label']}
                                            </span>
                                            <i class="bi bi-chevron-down small ms-1" style="transition:transform .2s"></i>
                                        </a>
                                        <div class="collapse collapse-submenu" id="{$submenuId}">
                                            {foreach $item['children'] as $child}
                                                <a href="{$child['url']}"
                                                   class="nav-link{if isset($currentPath) && $currentPath === $child['url']} active{/if}">
                                                    <i class="bi bi-dash"></i>
                                                    {$child['label']}
                                                </a>
                                            {/foreach}
                                        </div>
                                    {/if}
                                {/foreach}
                            </nav>
                        {/block}
                    </div>
                {/if}

                {* ── Page content ───────────────────────────────── *}
                <div id="page-content-wrapper" class="flex-grow-1 overflow-hidden">

                    {* Banner déplacé ici pour éviter la bande blanche au-dessus de la sidebar *}
                    {if isset($currentPath) && $currentPath === '/' && file_exists('app/images/header-banner.jpg')}
                        <img src="/app/images/header-banner.jpg" class="img-fluid custom-img w-100 d-block" alt="Bannière">
                    {/if}

                    <div class="container-fluid">
                        {block content}{/block}
                        <div id="saveIndicator" title="Penser à enregistrer les modifications">
                            <i class="bi bi-save"></i>
                        </div>
                    </div>
                </div>

            </div>{* /wrapper *}
        </main>

        <footer class="bg-dark text-white">
            <div class="container-fluid">
                <p class="mb-0">
                    <a href="https://github.com/jebissey/MyClub/releases">V{$currentVersion}</a> &#169; JEB
                    <a href="/legal/notice">Mentions légales</a>
                    <a href="https://myclub.ovh/menu/show/article/28" target="_blank">Tutoriels</a>
                </p>
            </div>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="/app/modules/Common/js/layout.js"></script>
    {block scripts}{/block}
</body>
</html>
